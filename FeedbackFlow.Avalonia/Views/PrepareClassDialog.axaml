<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="350"
        x:Class="FeedbackFlow.Avalonia.Views.PrepareClassDialog"
        Title="Prepare Next Class"
        Width="500" Height="350"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        
        <!-- Header Info -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <TextBlock x:Name="TxtStudentName" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock x:Name="TxtNextDate" Opacity="0.7"/>
        </StackPanel>

        <!-- Form Fields -->
        <StackPanel Grid.Row="1" Spacing="12">
            <StackPanel>
                <TextBlock Text="Learning Material" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                    <TextBlock Grid.Column="0" 
                               x:Name="TxtMaterialPath" 
                               Text="No material assigned"
                               Opacity="0.6"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BtnBrowse" 
                                Content="Browse" 
                                Click="BtnBrowse_Click"
                                Padding="12,4"/>
                        <Button x:Name="BtnClearMaterial"
                                Content="Clear" 
                                Click="BtnClearMaterial_Click"
                                Padding="12,4"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
            
            <StackPanel>
                <TextBlock Text="Class Description" FontWeight="SemiBold"/>
                <TextBox x:Name="TextDescription" 
                         Watermark="Enter class description (optional)"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="120"
                         Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="8"
                    Margin="0,20,0,0">
            <Button Content="Cancel" 
                    Click="BtnCancel_Click"
                    MinWidth="80"/>
            <Button Content="Save" 
                    Click="BtnSave_Click"
                    MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>
